{
  "name": "myst-starlight-blueprint",
  "private": true,
  "type": "module",
  "scripts": {
    "myst:build": "cd site/myst && myst build --site",
    "transpile": "java -jar tool/build/libs/tool-jvm.jar --in site/myst/_build/site/content --out site/src/content/docs",
    "site:build": "cd site && npm run build",
    "pipeline": "npm run myst:build && npm run transpile && npm run site:build"
  }
}
